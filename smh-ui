-- [[ XENO EXECUTOR - SILENT FAST M1 & DRAGON TALON FIX ]] --

local player = game.Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")
local RunService = game:GetService("RunService")

_G.AutoFarm = true
_G.FastM1 = true

-- 1. GELİŞMİŞ M1 SİSTEMİ (Vuruş Gözükmez ve Tüm Stillerde Çalışır)
spawn(function()
    while task.wait() do
        if _G.FastM1 and _G.AutoFarm then
            pcall(function()
                local char = player.Character
                local tool = char:FindFirstChildOfClass("Tool")
                
                if tool then
                    -- Dragon Talon vb. için Direct Click Simulation
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton1(Vector2.new(851, 158)) -- Ekranın ortasına sanal tıklama
                    
                    -- Vuruşun 'Gözükmemesi' (Animasyon İptali)
                    local humanoid = char:FindFirstChildOfClass("Humanoid")
                    if humanoid then
                        -- Animasyonları anlık durdurarak vuruş efektini gizler
                        for _, anim in pairs(humanoid:GetPlayingAnimationTracks()) do
                            if anim.Name:lower():find("attack") or anim.Name:lower():find("slash") then
                                anim:Stop()
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- 2. BYPASS TWEEN TP (Hızı 350'ye Çıkardım)
local function bypassTP(targetCFrame)
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local root = player.Character.HumanoidRootPart
        local dist = (root.Position - targetCFrame.Position).Magnitude
        local speed = 350 -- Daha hızlı geçiş
        local info = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
        game:GetService("TweenService"):Create(root, info, {CFrame = targetCFrame}):Play()
    end
end

-- 3. ANA FARM DÖNGÜSÜ
spawn(function()
    while task.wait(0.1) do
        if _G.AutoFarm then
            local target = nil
            local dist = math.huge
            
            -- En yakın düşmanı bul (Menzil Kontrolü)
            for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                    local d = (player.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
                    if d < dist then
                        dist = d
                        target = v
                    end
                end
            end

            if target then
                -- MESAFE AYARI: Dragon Talon için 5-6 birim idealdir
                bypassTP(target.HumanoidRootPart.CFrame * CFrame.new(0, 6, 0))
                
                -- Silahı kontrol et
                if not player.Character:FindFirstChildOfClass("Tool") then
                    local weapon = player.Backpack:FindFirstChild("Dragon Talon") or 
                                 player.Backpack:FindFirstChild("Combat") or 
                                 player.Backpack:FindFirstChildOfClass("Tool")
                    if weapon then weapon.Parent = player.Character end
                end
            end
        end
    end
end)

-- 4. NOCLIP & GÖRÜNMEZ VURUŞ DESTEĞİ
RunService.Stepped:Connect(function()
    if _G.AutoFarm and player.Character then
        for _, v in pairs(player.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

print("Dragon Talon Fix & Silent M1 Loaded!")
