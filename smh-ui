if _G.FarmActive then _G.FarmActive = false end
task.wait(0.5)
_G.FarmActive = true

local player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")

-- 1. GELİŞMİŞ TWEEN (IŞINLANMA) FONKSİYONU
-- Karakteri ban yemeden hızlıca hedefe kaydırır.
local function toTarget(targetCFrame)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local distance = (char.HumanoidRootPart.Position - targetCFrame.Position).Magnitude
        local speed = 80 -- Güvenli hız sınırı
        local info = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)
        
        local tween = TweenService:Create(char.HumanoidRootPart, info, {CFrame = targetCFrame})
        tween:Play()
        return tween
    end
end

-- 2. GÖREV ALMA MANTIĞI (Örnek: Bandit Görevi)
-- Not: Gerçek scriptlerde bu kısım oyuncunun seviyesine göre dinamik değişir.
local function getQuest(questName, npcPos)
    -- NPC'nin yanına git
    toTarget(npcPos)
    task.wait(1)
