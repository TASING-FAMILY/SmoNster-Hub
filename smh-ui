-- 2. BUTON SİSTEMİ
local function createToggle(name, pos, varName)
    local btn = Instance.new("TextButton", main)
    btn.Text = name .. ": KAPALI"
    btn.Size = UDim2.new(0, 210, 0, 50)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

    btn.MouseButton1Click:Connect(function()
        _G[varName] = not _G[varName]
        btn.Text = name .. ": " .. (_G[varName] and "AÇIK" or "KAPALI")
        btn.BackgroundColor3 = _G[varName] and Color3.fromRGB(90, 20, 160) or Color3.fromRGB(30, 30, 40)
    end)
end

createToggle("Oto Farm (Üstten)", UDim2.new(0, 10, 0, 60), "AutoFarm")
createToggle("Sessiz Vuruş (Fix)", UDim2.new(0, 10, 0, 120), "SilentM1")

-- 3. HATA GİDERİLMİŞ VURUŞ SİSTEMİ (Dragon Talon & M1 Fix)
spawn(function()
    while task.wait() do
        if _G.SilentM1 and _G.AutoFarm then
            pcall(function()
                local char = player.Character
                local tool = char:FindFirstChildOfClass("Tool")
                
                if tool then
                    -- 1. Yöntem: Sanal Tıklama
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton1(Vector2.new(9e9, 9e9))
                    
                    -- 2. Yöntem: Blox Fruits Attack Remote (Sinyali Doğrular)
                    -- Bu kısım hasarın kesin gitmesini sağlar
                    local args = { [1] = 0.1 } -- Vuruş gücü/zamanlaması
                    ReplicatedStorage.Remotes.Validator:FireServer(unpack(args))
                    
                    -- Animasyon Gizleme (Hafif Gecikmeli - Vuruş Kaybolmasın Diye)
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        task.spawn(function()
                            task.wait(0.05) -- Sunucunun vuruşu algılaması için mini bekleme
                            for _, track in pairs(hum:GetPlayingAnimationTracks()) do
                                track:Stop(0)
                            end
                        end)
                    end
                    
                    -- Efekt Temizliği
                    for _, v in pairs(char:GetChildren()) do
                        if v.Name:find("Effect") or v.Name:find("Slash") then v:Destroy() end
                    end
                end
            end)
        end
    end
end)

-- 4. BYPASS TP (Yükseklik Fix: 9 Birim)
-- 11 birim bazen çok uzak kalabiliyor, 9 birim en dengelisidir.
local function bypassTP(targetCFrame)
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if root then
        local dist = (root.Position - targetCFrame.Position).Magnitude
        local speed = 320 
        local info = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
        TweenService:Create(root, info, {CFrame = targetCFrame}):Play()
    end
end

-- 5. FARM DÖNGÜSÜ
spawn(function()
    while task.wait(0.1) do
        if _G.AutoFarm then
            local target = nil
            local dist = math.huge
            for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                    local d = (player.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
                    if d < dist then dist = d; target = v end
                end
            end

            if target and target:FindFirstChild("HumanoidRootPart") then
                -- Düşmanın 9 birim yukarısına TP ol
                bypassTP(target.HumanoidRootPart.CFrame * CFrame.new(0, 9, 0))
                
                -- Silahı kuşan
                if not player.Character:FindFirstChildOfClass("Tool") then
                    local weapon = player.Backpack:FindFirstChildOfClass("Tool")
                    if weapon then weapon.Parent = player.Character end
                end
            end
        end
    end
end)

