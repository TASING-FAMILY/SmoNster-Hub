-- 2. ULTRA SILENT ATTACK & DRAGON TALON FIX
RunService.RenderStepped:Connect(function()
    if _G.Mode ~= "None" then
        pcall(function()
            local char = player.Character
            -- Animasyon İptali
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                for _, track in pairs(hum:GetPlayingAnimationTracks()) do track:Stop(0) end
            end
            -- Vuruş Sinyali (Her Karede Zorla Gönder)
            ReplicatedStorage.Remotes.CommF_:InvokeServer("Attack", { [1] = 0.1 })
            -- Silah/Meyve Kontrolü
            local tool = char:FindFirstChildOfClass("Tool")
            if not tool then
                local t = player.Backpack:FindFirstChildOfClass("Tool")
                if t then t.Parent = char end
            end
        end)
    end
end)

-- 3. HEDEF BULUCU (EN YAKIN VEYA GÖREVE GÖRE)
local function getTarget()
    local target, dist = nil, math.huge
    local enemies = game.Workspace.Enemies:GetChildren()
    
    for _, v in pairs(enemies) do
        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            -- Mastery Modunda en düşük canlıyı seçebiliriz, şu an en yakını seçiyoruz
            local d = (player.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; target = v end
        end
    end
    return target
end

