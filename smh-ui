local function createToggle(name, pos, varName)
    local btn = Instance.new("TextButton", main)
    btn.Text = name .. ": OFF"
    btn.Size = UDim2.new(0, 210, 0, 50)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    btn.MouseButton1Click:Connect(function()
        _G[varName] = not _G[varName]
        btn.Text = name .. ": " .. (_G[varName] and "ON" or "OFF")
        btn.BackgroundColor3 = _G[varName] and Color3.fromRGB(80, 0, 180) or Color3.fromRGB(25, 25, 35)
    end)
end

createToggle("Sürekli Farm", UDim2.new(0, 10, 0, 60), "AutoFarm")
createToggle("Görünmez M1", UDim2.new(0, 10, 0, 120), "SilentM1")

-- 3. ABSOLUTE SILENT M1 & DRAGON TALON FIX
RunService.RenderStepped:Connect(function()
    if _G.SilentM1 and _G.AutoFarm then
        pcall(function()
            local char = player.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                -- Tüm animasyonları her karede (frame) zorla durdur
                for _, track in pairs(hum:GetPlayingAnimationTracks()) do
                    track:Stop(0)
                end
            end
            -- Dövüş Stili Vuruş Sinyali
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then
                -- Blox Fruits'in ana vuruş sinyali
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Attack", { [1] = 0.1 })
                -- Efekt temizliği
                for _, v in pairs(char:GetChildren()) do
                    if v.Name:find("Effect") or v.Name:find("Slash") then v:Destroy() end
                end
            end
        end)
    end
end)

-- 4. BYPASS TP & FARM (MESAFE FIX: 8 Birim)
local function getNearestEnemy()
    local target, dist = nil, math.huge
    for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            local d = (player.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; target = v end
        end
    end
    return target
end

spawn(function()
    while true do
        task.wait(0.01)
        if _G.AutoFarm then
            pcall(function()
                local enemy = getNearestEnemy()
                if enemy then
                    local root = player.Character.HumanoidRootPart
                    local enemyRoot = enemy.HumanoidRootPart
                    
                    -- NPC'lerin 8 birim yukarısı (En dengeli vuruş mesafesi)
                    local targetPos = enemyRoot.CFrame * CFrame.new(0, 8, 0)
                    root.CFrame = targetPos -- Bypass için saniyelik eşitleme
                    
                    -- Silah Kuşanma
                    if not player.Character:FindFirstChildOfClass("Tool") then
                        local tool = player.Backpack:FindFirstChildOfClass("Tool")
                        if tool then tool.Parent = player.Character end
                    end
                end
            end)
        end
    end
end)

