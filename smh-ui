local function createModBtn(name, pos, modeName)
    local btn = Instance.new("TextButton", main)
    btn.Text = name
    btn.Size = UDim2.new(0, 230, 0, 40)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)

    btn.MouseButton1Click:Connect(function()
        _G.Mode = (_G.Mode == modeName) and "None" or modeName
        print("Mod Değişti: " .. _G.Mode)
        -- Görsel geri bildirim
        for _, v in pairs(main:GetChildren()) do
            if v:IsA("TextButton") then v.BackgroundColor3 = Color3.fromRGB(30, 30, 40) end
        end
        if _G.Mode ~= "None" then btn.BackgroundColor3 = Color3.fromRGB(100, 20, 200) end
    end)
end

