-- 2. BUTON OLUŞTURUCU
local function createToggle(name, pos, varName)
    local btn = Instance.new("TextButton", main)
    btn.Text = name .. ": OFF"
    btn.Size = UDim2.new(0, 200, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    btn.MouseButton1Click:Connect(function()
        _G[varName] = not _G[varName]
        btn.Text = name .. ": " .. (_G[varName] and "ON" or "OFF")
        btn.BackgroundColor3 = _G[varName] and Color3.fromRGB(110, 30, 180) or Color3.fromRGB(35, 35, 45)
    end)
end

createToggle("Auto Farm (Overhead)", UDim2.new(0, 10, 0, 50), "AutoFarm")
createToggle("Silent M1 (No Anim)", UDim2.new(0, 10, 0, 105), "SilentM1")

-- 3. BYPASS TP SİSTEMİ (NPC Üstü)
local function bypassTP(targetCFrame)
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if root then
        local dist = (root.Position - targetCFrame.Position).Magnitude
        local speed = 300 
        local info = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
        TweenService:Create(root, info, {CFrame = targetCFrame}):Play()
    end
end

-- 4. ULTRA SILENT M1 & DRAGON TALON FIX
spawn(function()
    while task.wait() do
        if _G.SilentM1 and _G.AutoFarm then
            pcall(function()
                local char = player.Character
                local tool = char:FindFirstChildOfClass("Tool")
                if tool then
                    -- Dragon Talon ve tüm stilleri tetikleyen sanal tıklama
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton1(Vector2.new(9e9, 9e9))
                    
                    -- Animasyonları Gizle
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        for _, track in pairs(hum:GetPlayingAnimationTracks()) do
                            track:Stop(0)
                        end
                    end
                    
                    -- Vuruş Efektlerini Sil
                    for _, v in pairs(char:GetChildren()) do
                        if v:IsA("Part") or v:IsA("MeshPart") then
                            if v.Name:find("Effect") or v.Name:find("Slash") then v:Destroy() end
                        end
                    end
                end
            end)
        end
    end
end)

-- 5. FARM DÖNGÜSÜ
spawn(function()
    while task.wait(0.1) do
        if _G.AutoFarm then
            local target = nil
            local dist = math.huge
            for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                    local d = (player.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
                    if d < dist then dist = d; target = v end
                end
            end

            if target and target:FindFirstChild("HumanoidRootPart") then
                -- NPC'lerin 11 birim yukarısında konumlan (Bypass TP)
                bypassTP(target.HumanoidRootPart.CFrame * CFrame.new(0, 11, 0))
                
                -- Silahı otomatik eline al
                if not player.Character:FindFirstChildOfClass("Tool") then
                    local weapon = player.Backpack:FindFirstChildOfClass("Tool")
                    if weapon then weapon.Parent = player.Character end
                end
            end
        end
    end
end)

