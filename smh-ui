-- ANA ÇALIŞTIRICI
spawn(function()
    while _G.FarmActive do
        if autoLevel then
            -- 1. Adım: En yakın düşmanı bul
            local target = nil
            for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                    target = v
                    break
                end
            end
            
            if target then
                -- 2. Adım: Düşmanın üstüne git ve saldır
                local enemyPart = target:FindFirstChild("HumanoidRootPart")
                if enemyPart then
                    -- Düşmanın 10 birim üzerinde dur (Vurulmamak için)
                    toTarget(enemyPart.CFrame * CFrame.new(0, 10, 0))
                    
                    -- Dövüş stiliyle vur
                    local tool = player.Character:FindFirstChildOfClass("Tool")
                    if tool then 
                        tool:Activate() 
                    else
                        -- Envanterden silahı otomatik çek
                        local combat = player.Backpack:FindFirstChild("Combat") or player.Backpack:FindFirstChildOfClass("Tool")
                        if combat then combat.Parent = player.Character end
                    end
                end
            else
                -- Düşman yoksa görev bölgesine veya spawn noktasına git
                print("Düşman aranıyor...")
            end
        end
        task.wait(0.1)
    end
end)
