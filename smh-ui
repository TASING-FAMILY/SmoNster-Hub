-- [[ XENO EXECUTOR - ADVANCED AUTO M1 & LEVEL FARM ]] --

local player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

_G.AutoFarm = true
_G.FastAttack = true -- Auto M1 aktif

-- 1. SEVİYE VERİ TABANI (Örnek)
local QuestData = {
    {Level = 0, QuestName = "BanditQuest1", MonsterName = "Bandit", NPCPos = Vector3.new(1059, 15, 1550)},
    {Level = 10, QuestName = "MonkeyQuest1", MonsterName = "Monkey", NPCPos = Vector3.new(-1598, 35, 150)}
}

-- 2. AUTO M1 (FAST ATTACK) MEKANİZMASI
-- Animasyon beklemeden vuruş sinyali gönderir.
spawn(function()
    while task.wait() do
        if _G.AutoFarm and _G.FastAttack then
            pcall(function()
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then
                    -- Standart tıklama yerine hızlı aktivasyon
                    tool:Activate()
                    -- Bazı executorlarda M1 vuruşunu hızlandırmak için:
                    -- game:GetService("VirtualUser"):CaptureController()
                    -- game:GetService("VirtualUser"):ClickButton1(Vector2.new(851, 158), game.Workspace.CurrentCamera.CFrame)
                end
            end)
        end
    end
end)

-- 3. BYPASS TELEPORT (TWEEN)
local function bypassTP(targetPos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local dist = (char.HumanoidRootPart.Position - targetPos).Magnitude
        local speed = 300 -- Bypass için ideal hız
        local info = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(char.HumanoidRootPart, info, {CFrame = CFrame.new(targetPos)})
        tween:Play()
        return tween
    end
end

-- 4. ANA DÖNGÜ (QUEST & FARM)
spawn(function()
    while _G.AutoFarm do
        local level = player.Data.Level.Value
        local quest = QuestData[1]
        
        -- Mevcut seviyeye uygun görevi seç
        for _, q in pairs(QuestData) do
            if level >= q.Level then quest = q end
        end
        
        -- GÖREV KONTROLÜ
        local hasQuest = player.PlayerGui.Main:FindFirstChild("Quest").Visible
        if not hasQuest then
            bypassTP(quest.NPCPos)
            task.wait(1)
            -- Sunucuya görev alma isteği gönder (Blox Fruits Remote)
            ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest", quest.QuestName, 1)
        else
            -- DÜŞMAN KONTROLÜ VE SALDIRI
            local enemy = nil
            for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                if v.Name == quest.MonsterName and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                    enemy = v
                    break
                end
            end
            
            if enemy then
                local root = enemy:FindFirstChild("HumanoidRootPart")
                if root then
                    -- Düşmanın dibine değil, 6-7 birim üstüne/yanına git (Vuruş alanı için)
                    bypassTP(root.Position + Vector3.new(0, 7, 0))
                    
                    -- Silah Kontrolü (Combat/Sword)
                    if not player.Character:FindFirstChildOfClass("Tool") then
                        local sword = player.Backpack:FindFirstChild("Combat") or player.Backpack:FindFirstChildOfClass("Tool")
                        if sword then sword.Parent = player.Character end
                    end
                end
            else
                -- Düşman yoksa spawn noktasına git
                bypassTP(quest.NPCPos + Vector3.new(0, 50, 0))
            end
        end
        task.wait(0.1)
    end
end)

-- 5. NOCLIP (Duvarlardan Geçme)
RunService.Stepped:Connect(function()
    if _G.AutoFarm and player.Character then
        for _, v in pairs(player.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

print("M1 Fast Attack & Auto Level Aktif!")
